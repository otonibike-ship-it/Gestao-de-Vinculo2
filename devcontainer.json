{
  "name": "Gestão de Vínculo — Dev Container",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "api",
  "workspaceFolder": "/app",

  // Encaminhamento de portas
  "forwardPorts": [3000, 8000, 5432, 6379, 8080],
  "portsAttributes": {
    "3000": { "label": "Frontend (Next.js)", "onAutoForward": "openBrowser" },
    "8000": { "label": "API (Backend)", "onAutoForward": "notify" },
    "8080": { "label": "Adminer (DB GUI)", "onAutoForward": "notify" }
  },

  // Extensões recomendadas para toda a equipe
  "customizations": {
    "vscode": {
      "extensions": [
        // Linguagens
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "ms-python.isort",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",

        // Docker & containers
        "ms-azuretools.vscode-docker",
        "ms-vscode-remote.remote-containers",

        // Git
        "eamodio.gitlens",
        "mhutchie.git-graph",

        // Banco de dados
        "cweijan.vscode-postgresql-client2",

        // REST / API
        "humao.rest-client",

        // Qualidade de código
        "streetsidesoftware.code-spell-checker",
        "streetsidesoftware.code-spell-checker-portuguese-brazilian",
        "sonarsource.sonarlint-vscode",

        // Produtividade
        "christian-kohler.path-intellisense",
        "aaron-bond.better-comments",
        "usernamehw.errorlens",
        "bradlc.vscode-tailwindcss"
      ],

      "settings": {
        // Editor
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.rulers": [88, 120],

        // Python
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter",
          "editor.formatOnSave": true
        },
        "isort.args": ["--profile", "black"],

        // JavaScript / TypeScript
        "[javascript][typescript][typescriptreact][javascriptreact]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },

        // Git
        "git.autofetch": true,
        "gitlens.hovers.currentLine.over": "line",

        // Terminal
        "terminal.integrated.defaultProfile.linux": "bash",

        // Arquivos ignorados no explorador
        "files.exclude": {
          "**/__pycache__": true,
          "**/.pytest_cache": true,
          "**/node_modules": true,
          "**/.next": true
        }
      }
    }
  },

  // Comandos executados após o container subir
  "postCreateCommand": "echo '✅ Dev Container pronto! Rode: docker-compose up' && pip install --upgrade pip 2>/dev/null || true",

  // Usuário não-root dentro do container
  "remoteUser": "vscode"
}
