# ─────────────────────────────────────────────────────────────
# Gestão de Vínculo — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositório
# ─────────────────────────────────────────────────────────────

# ── Ambiente ─────────────────────────────────────────────────
# Valores: development | staging | production
ENVIRONMENT=development

# ── Banco de dados (PostgreSQL) ───────────────────────────────
DATABASE_URL=postgresql://vinculo_user:vinculo_pass@postgres:5432/vinculo_db
# Para rodar fora do Docker (testes locais):
# DATABASE_URL=postgresql://vinculo_user:vinculo_pass@localhost:5432/vinculo_db

POSTGRES_USER=vinculo_user
POSTGRES_PASSWORD=vinculo_pass
POSTGRES_DB=vinculo_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Autenticação (JWT) ────────────────────────────────────────
# Gere uma chave segura: openssl rand -hex 32
JWT_SECRET=SUBSTITUA_POR_CHAVE_SEGURA
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── API ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Gestão de Vínculo

# ── Storage (S3 / compatível) ─────────────────────────────────
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1
AWS_S3_BUCKET=gestao-vinculo-docs

# ── Worker / Filas ────────────────────────────────────────────
WORKER_CONCURRENCY=4
WORKER_QUEUE_NAME=vinculo-jobs

# ── Notificações (opcional) ──────────────────────────────────
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@suaempresa.com.br

# ── Observabilidade (opcional) ───────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
